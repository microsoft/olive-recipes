{
    "input_model": {
        "type": "HFModel",
        "model_path": "microsoft/Phi-4-reasoning"
    },
    "recipe_metadata": {
        "version": "1.0.0",
        "validated_with": {
            "qairt_sdk": "2.45.0",
            "qairt_dev": "0.5.0",
            "python": "3.10"
        }
    },
    "passes": {
        "qp": {
            "type": "QairtPreparation",
            "script_path": "phi4_reasoning_script.py",
            "script_config": {
                "PLATFORM_GEN": 2
            }
        },
        "qgab": {
            "type": "QairtGenAIBuilder",
            "log_level": "INFO",
            "backend": "HTP",
            "soc_details": "chipset:SC8380XP",
            "vtcm_size_in_mb": 8,
            "hvx_threads": 8,
            "extended_udma": false,
            "sequence_lengths": [32, 128],
            "native_kv": true,
            "multi_graph": true
        },
        "qe": {
            "type": "QairtEncapsulation",
            "log_level": "ERROR",
            "run_checker": "true"
        }
    },
    "log_severity_level": 1,
    "output_dir": "models/phi4_reasoning-qairt-htp-sc8380xp",
    "cache_dir": "cache",
    "no_artifacts": true
}
