{
    "input_model": {
        "type": "HFModel",
        "model_path": "microsoft/Phi-4-reasoning"
    },
    "passes": {
        "qp": {
            "type": "QairtPreparation",
            "script_path": "phi4_reasoning_script.py"
        },
        "qgab": {
            "type": "QairtGenAIBuilder",
            "log_level": "INFO",
            "backend": "HTP",
            "soc_details": "chipset:SC8480XP",
            "vtcm_size_in_mb": 8,
            "hvx_threads": 8,
	    "extended_udma": true,
	    "sequence_lengths": [32, 128],
            "native_kv": true,
            "multi_graph": true
        },
        "qe": {
            "type": "QairtEncapsulation",
            "log_level": "ERROR",
            "run_checker": "true"
        }
    },
    "log_severity_level": 1,
    "output_dir": "models/phi4_reasoning-qairt-htp-sc8480xp",
    "cache_dir": "cache",
    "no_artifacts": true
}
