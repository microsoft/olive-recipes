{
    "$schema": "https://github.com/microsoft/olive-recipes/raw/refs/heads/main/.aitk/configs/config_schema.json",
    "name": "Convert to Intel CPU/NPU/GPU",
    "oliveFile": {
        "audio_processor_config_default.json": "OpenVINO/audio_processor_config_default.json",
        "whisper_large_v3_turbo_default_ov_npu.json": "OpenVINO/whisper_large_v3_turbo_default_ov_npu.json",
        "whisper_large_v3_turbo_encapsulate.json": "OpenVINO/whisper_large_v3_turbo_encapsulate.json"
    },
    "isIntel": true,
    "evalNoDataConfig": true,
    "executeRuntimeFeatures": [
        "WP"
    ],
    "evaluationRuntimeFeatures": [
        "WP"
    ],
    "addCpu": true,
    "runtime": {
        "autoGenerated": true,
        "name": "Evaluate on",
        "type": "enum",
        "displayNames": [
            "Intel CPU",
            "Intel NPU",
            "Intel GPU"
        ],
        "path": "systems.local_system.accelerators.0.device",
        "values": [
            "cpu",
            "npu",
            "gpu"
        ],
        "readOnly": false
    },
    "optimizationPaths": [
        {
            "path": "passes.aitkpython.model_precision"
        }
    ],
    "optimizationDefault": "fp16",
    "aitkPython": "ov_workflow.py",
    "sections": [
        {
            "autoGenerated": true,
            "name": "Convert",
            "phase": "Conversion",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Convert to ONNX format",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        },
        {
            "name": "Quantize",
            "phase": "Quantization",
            "parameters": [
                {
                    "name": "Precision",
                    "description": "Precision of model",
                    "type": "enum",
                    "displayNames": [
                        "Fp16"
                    ],
                    "displayType": "RadioGroup",
                    "path": "passes.aitkpython.model_precision",
                    "values": [
                        "fp16"
                    ]
                }
            ],
            "disableToggleGeneration": true,
            "toggle": {
                "name": "Quantize model",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        },
        {
            "name": "Evaluate",
            "phase": "Evaluation",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Evaluate model performance",
                "type": "bool",
                "path": "evaluator",
                "actions": [
                    [],
                    [
                        {
                            "type": "delete",
                            "path": "evaluator"
                        }
                    ]
                ]
            }
        }
    ]
}
