{
    "$schema": "https://github.com/microsoft/olive-recipes/raw/refs/heads/main/.aitk/configs/config_schema.json",
    "name": "Convert to AMD NPU",
    "oliveFile": {
        "gpt-oss-20b_quark_vitisai_llm.json": "VitisAI/gpt-oss-20b_quark_vitisai_llm.json"
    },
    "isLLM": true,
    "evalRuntime": "AMDNPU",
    "isGPUSuggested": true,
    "runtimeOverwrite": {
        "executeRequirement": "AMD/Quark_py3.12.13"
    },
    "epMinVersions": {
        "VitisAIExecutionProvider": "1.8.50"
    },
    "runtime": {
        "autoGenerated": true,
        "name": "Evaluate on",
        "type": "enum",
        "displayNames": [
            "CPU"
        ],
        "path": "systems.local_system.accelerators.0.execution_providers.0",
        "values": [
            "CPUExecutionProvider"
        ],
        "readOnly": false
    },
    "optimizationPaths": [
        {
            "path": "passes.aitkpython.precision"
        }
    ],
    "optimizationDefault": "int4",
    "aitkPython": "gpt-oss-20b_vitis_ai_config.py",
    "sections": [
        {
            "autoGenerated": true,
            "name": "Convert",
            "phase": "Conversion",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Convert to ONNX format",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        }
    ]
}
