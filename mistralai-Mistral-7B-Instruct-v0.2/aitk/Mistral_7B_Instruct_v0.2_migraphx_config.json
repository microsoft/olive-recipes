{
    "input_model": {
        "type": "HfModel",
        "model_path": "mistralai/Mistral-7B-Instruct-v0.2"
    },
    "systems": {
        "host_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "cpu",
                    "execution_providers": [
                        "CPUExecutionProvider"
                    ]
                }
            ]
        },
        "target_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "MIGraphXExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "mb": {
            "type": "ModelBuilder",
            "precision": "int4"
        }
    },
    "host": "host_system",
    "target": "target_system",
    "log_severity_level": 1,
    "output_dir": "model/mistral",
    "cache_dir": "cache",
    "no_artifacts": true,
    "evaluate_input_model": false
}