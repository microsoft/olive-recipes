{
    "$schema": "https://github.com/microsoft/olive-recipes/raw/refs/heads/main/.aitk/configs/config_schema.json",
    "name": "Conversion Sample",
    "evalNoDataConfig": true,
    "disableConversionGeneration": true,
    "runtime": {
        "autoGenerated": true,
        "name": "Evaluate on",
        "type": "enum",
        "displayNames": [
            "CPU"
        ],
        "path": "systems.local_system.accelerators.0.execution_providers.0",
        "values": [
            "CPUExecutionProvider"
        ],
        "readOnly": false
    },
    "sections": [
        {
            "name": "Convert",
            "phase": "Conversion",
            "parameters": [],
            "disableToggleGeneration": true,
            "toggle": {
                "name": "Convert the model",
                "type": "bool",
                "path": "passes",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        },
        {
            "name": "Evaluate",
            "phase": "Evaluation",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Evaluate model performance",
                "type": "bool",
                "path": "evaluator",
                "actions": [
                    [],
                    [
                        {
                            "type": "delete",
                            "path": "evaluator"
                        }
                    ]
                ]
            }
        }
    ]
}
