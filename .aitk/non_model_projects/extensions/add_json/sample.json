{
    "input_model": {
        "type": "HfModel",
        "model_path": "MODEL_PATH",
        "task": "MODEL_TASK"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "cpu",
                    "execution_providers": [
                        "CPUExecutionProvider"
                    ]
                }
            ]
        }
    },
    "evaluators": {
        "common_evaluator": {
        }
    },
    "passes": {
         "conversion": {
            "type": "OnnxConversion",
            "target_opset": 17,
            "save_as_external_data": true
        }
    },
    "evaluator": "common_evaluator",
    "evaluate_input_model": false,
    "target": "local_system",
    "cache_dir": "cache",
    "output_dir": "model/output"
}
