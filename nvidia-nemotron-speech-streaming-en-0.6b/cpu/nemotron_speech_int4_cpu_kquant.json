{
    "input_model": {
        "type": "HfModel",
        "model_path": "nvidia/nemotron-speech-streaming-en-0.6b"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "cpu",
                    "execution_providers": ["CPUExecutionProvider"]
                }
            ]
        }
    },
    "passes": {
        "export": {
            "type": "NemotronExport",
            "streaming": true,
            "chunk_size": 0.56,
            "left_chunks": 10,
            "device": "cpu"
        },
        "fusion": {
            "type": "OrtTransformersOptimization",
            "model_type": "conformer",
            "num_heads": 8,
            "hidden_size": 1024,
            "opt_level": 0,
            "only_onnxruntime": false,
            "optimization_options": {
                "use_multi_head_attention": false
            }
        },
        "quantization": {
            "type": "OnnxBlockWiseRtnQuantization",
            "bits": 4,
            "block_size": 32,
            "is_symmetric": true,
            "accuracy_level": 4
        }
    },
    "target": "local_system",
    "output_dir": "build/onnx_models_int4",
    "no_artifacts": true
}