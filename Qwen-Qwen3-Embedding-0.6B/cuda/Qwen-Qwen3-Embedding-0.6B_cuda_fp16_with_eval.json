{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen3-Embedding-0.6B",
        "load_kwargs": {
            "torch_dtype": "float16"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "CUDAExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "fp16",
            "extra_options": {
                "include_hidden_states": 1
            }
        },
        "t": {
            "type": "GraphSurgeries",
            "surgeries": [
                {
                    "surgeon": "TieWordEmbeddings"
                }
            ]
        }
    },
    "evaluators": {
        "mteb": {
            "type": "MTEBEvaluator",
            "tasks": [
                "STS17",
                "NFCorpus",
                "ArguAna",
                "SciFact"
            ],
            "batch_size": 32
        }
    },
    "evaluator": "mteb",
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model_cuda_fp16",
    "cache_dir": "cache_cuda_fp16",
    "evaluate_input_model": false
}
