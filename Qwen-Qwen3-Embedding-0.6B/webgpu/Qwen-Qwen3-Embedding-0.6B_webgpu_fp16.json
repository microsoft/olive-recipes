{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen3-Embedding-0.6B",
        "load_kwargs": {
            "torch_dtype": "float16"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "WebGpuExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "fp16",
            "extra_options": {
                "include_hidden_states": 1
            }
        },
        "t": {
            "type": "GraphSurgeries",
            "surgeries": [
                {
                    "surgeon": "TieWordEmbeddings"
                }
            ]
        }
    },
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model",
    "cache_dir": "cache",
    "no_artifacts": true
}
