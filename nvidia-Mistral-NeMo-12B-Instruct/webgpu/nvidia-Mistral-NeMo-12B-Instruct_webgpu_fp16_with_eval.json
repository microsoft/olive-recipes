{
    "input_model": {
        "type": "HfModel",
        "model_path": "mistralai/Mistral-Nemo-Instruct-2407",
        "load_kwargs": {
            "torch_dtype": "float16"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "WebGpuExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "fp16"
        }
    },
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model_webgpu_fp16",
    "cache_dir": "cache_webgpu_fp16",
    "evaluators": {
        "mmlu": {
            "type": "LMEvaluator",
            "tasks": [
                "mmlu"
            ],
            "batch_size": 1,
            "max_length": 2048,
            "provider_options": {
                "enable_skip_layer_norm_strict_mode": "1"
            }
        }
    },
    "evaluator": "mmlu",
    "evaluate_input_model": false
}
