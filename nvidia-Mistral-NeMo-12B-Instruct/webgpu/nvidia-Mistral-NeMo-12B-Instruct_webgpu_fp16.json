{
    "input_model": {
        "type": "HfModel",
        "model_path": "mistralai/Mistral-Nemo-Instruct-2407",
        "load_kwargs": {
            "torch_dtype": "float16"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "WebGpuExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "fp16"
        }
    },
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model_webgpu_fp16",
    "cache_dir": "cache_webgpu_fp16",
    "no_artifacts": true
}
