{
    "input_model": {
        "type": "HfModel",
        "model_path": "allenai/Olmo-3-7B-Instruct",
        "load_kwargs": {
            "torch_dtype": "float16"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "CUDAExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "fp16"
        }
    },
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model_cuda_fp16",
    "cache_dir": "cache_cuda_fp16",
    "no_artifacts": true
}
