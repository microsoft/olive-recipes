{
    "$schema": "https://github.com/microsoft/olive-recipes/raw/refs/heads/main/.aitk/configs/config_schema.json",
    "name": "Convert to Intel OpenVINO",
    "oliveFile": {
        "sam21_vision_encoder_ov.json": "OpenVINO/sam21_vision_encoder_ov.json",
        "sam21_mask_decoder_ov.json": "OpenVINO/sam21_mask_decoder_ov.json"
    },
    "isIntel": true,
    "evalMetrics": {
        "vision-encoder-latency-avg": "vision-encoder-latency-avg",
        "mask-decoder-latency-avg": "mask-decoder-latency-avg"
    },
    "evalNoDataConfig": true,
    "memoryGbSuggested": 30,
    "executeRuntimeFeatures": [
        "SAM"
    ],
    "evaluationRuntimeFeatures": [
        "SAM"
    ],
    "addCpu": false,
    "runtime": {
        "autoGenerated": true,
        "name": "Evaluate on",
        "type": "enum",
        "displayNames": [
            "Intel CPU",
            "Intel NPU",
            "Intel GPU"
        ],
        "path": "systems.local_system.accelerators.0.device",
        "values": [
            "cpu",
            "npu",
            "gpu"
        ],
        "readOnly": false
    },
    "optimizationPaths": [
        {
            "path": "passes.aitkpython",
            "name": "int8"
        }
    ],
    "optimizationDefault": "int8",
    "aitkPython": "sam2_ov_workflow.py",
    "sections": [
        {
            "autoGenerated": true,
            "name": "Convert",
            "phase": "Conversion",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Convert to ONNX format",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        }
    ]
}
