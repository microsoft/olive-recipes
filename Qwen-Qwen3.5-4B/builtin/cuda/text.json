{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen3.5-4B"
    },
    "passes": {
        "s": {
            "type": "SelectiveMixedPrecision",
            "algorithm": "kld_gradient",
            "bits": 4,
            "high_bits": 8,
            "ratio": 0.65,
            "sym": false,
            "group_size": 128
        },
        "m": {
            "type": "ModelBuilder",
            "precision": "int4",
            "extra_options": {
                "filename": "text.onnx"
            }
        },
        "r": {
            "type": "rtn",
            "bits": 8,
            "sym": false,
            "group_size": 128,
            "lm_head": true,
            "embeds": true,
            "overrides": {
                "lm_head": {"bits": 8},
                "model.embed_tokens": {"bits": 8}
            }
        }
    },
    "engine": {
        "target": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "CUDAExecutionProvider"
                    ]
                }
            ]
        }
    },
    "no_artifacts": true,
    "output_dir": "cuda/models/text.onnx"
}
