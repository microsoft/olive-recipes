{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen3-VL-2B-Instruct"
    },
    "passes": {
        "convert": { "type": "ModelBuilder", "precision": "int4", "extra_options": { "filename": "text.onnx", "hf_token": "false" } }
    },
    "engine": {
        "target": {
            "type": "LocalSystem",
            "accelerators": [{ "device": "gpu", "execution_providers": ["CUDAExecutionProvider"] }]
        }
    },
    "no_artifacts": true,
    "output_dir": "models/text.onnx"
}
