{
    "input_model": {
        "type": "HfModel",
        "model_path": "microsoft/resnet-50",
        "task": "image-classification",
        "io_config": {
            "input_names": [
                "pixel_values"
            ],
            "input_shapes": [
                [
                    1,
                    3,
                    224,
                    224
                ]
            ],
            "output_names": [
                "logits"
            ]
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "WebGpuExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "conversion": {
            "type": "OnnxConversion",
            "target_opset": 17,
            "save_as_external_data": true
        },
        "peephole": {
            "type": "OnnxPeepholeOptimizer",
            "save_as_external_data": true
        }
    },
    "target": "local_system",
    "cache_dir": "cache",
    "output_dir": "model/resnet_webgpu",
    "evaluate_input_model": false
}
