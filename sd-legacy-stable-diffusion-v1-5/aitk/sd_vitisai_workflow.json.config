{
    "$schema": "https://github.com/microsoft/olive-recipes/raw/refs/heads/main/.aitk/configs/config_schema.json",
    "name": "Convert to AMD NPU",
    "oliveFile": {
        "vitisai_config_unet.json": {
            "ref": "VitisAI/config_unet.json"
        },
        "vitisai_config_text_encoder.json": {
            "ref": "VitisAI/config_text_encoder.json"
        },
        "vitisai_config_vae_decoder.json": {
            "ref": "VitisAI/config_vae_decoder.json"
        },
        "vitisai_config_vae_encoder.json": {
            "ref": "VitisAI/config_vae_encoder.json"
        },
        "vitisai_config_safety_checker.json": {
            "ref": "VitisAI/config_safety_checker.json"
        }
    },
    "evalMetrics": {
        "text-encoder-latency-avg": "text-encoder-latency-avg",
        "unet-latency-avg": "unet-latency-avg",
        "vae-decoder-latency-avg": "vae-decoder-latency-avg"
    },
    "evalNoDataConfig": true,
    "runtimeOverwrite": {
        "autoGenerated": true,
        "executeRequirement": "General/CPU_py3.12.9"
    },
    "executeRuntimeFeatures": [
        "SD"
    ],
    "evaluationRuntimeFeatures": [
        "SD"
    ],
    "runtime": {
        "autoGenerated": true,
        "name": "Evaluate on",
        "type": "enum",
        "displayNames": [
            "AMD NPU"
        ],
        "path": "systems.target_system.accelerators.0.execution_providers.0",
        "values": [
            "VitisAIExecutionProvider"
        ],
        "readOnly": false
    },
    "optimizationPaths": [
        {
            "path": "passes.aitkpython.model_precision"
        }
    ],
    "optimizationDefault": "int8",
    "aitkPython": "sd_vitisai_workflow.py",
    "sections": [
        {
            "autoGenerated": true,
            "name": "Convert",
            "phase": "Conversion",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Convert to ONNX format",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        },
        {
            "name": "Optimization",
            "phase": "Quantization",
            "parameters": [
                {
                    "name": "Precision",
                    "description": "Precision of model",
                    "type": "enum",
                    "displayNames": [
                        "Int8"
                    ],
                    "displayType": "RadioGroup",
                    "path": "passes.aitkpython.model_precision",
                    "values": [
                        "int8"
                    ]
                }
            ],
            "disableToggleGeneration": true,
            "toggle": {
                "name": "Optimize model",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        },
        {
            "name": "Evaluate",
            "phase": "Evaluation",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Evaluate model performance",
                "type": "bool",
                "path": "evaluator",
                "actions": [
                    [],
                    [
                        {
                            "type": "delete",
                            "path": "evaluator"
                        }
                    ]
                ]
            }
        }
    ]
}
