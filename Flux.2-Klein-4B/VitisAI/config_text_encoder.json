{
    "input_model": {
        "type": "PyTorchModel",
        "model_path": "black-forest-labs/FLUX.2-klein-4B",
        "model_loader": "text_encoder_load",
        "model_script": "user_script.py",
        "io_config": {
            "input_names": ["input_ids", "attention_mask", "position_ids"],
            "output_names": ["prompt_embeds"],
            "dynamic_axes": {
                "input_ids":      {"0": "batch", "1": "sequence"},
                "attention_mask": {"0": "batch", "1": "sequence"},
                "position_ids":   {"0": "batch", "1": "sequence"},
                "prompt_embeds":  {"0": "batch", "1": "sequence"}
            }
        },
        "dummy_inputs_func": "text_encoder_conversion_inputs"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [{"device": "cpu", "execution_providers": ["CPUExecutionProvider"]}]
        }
    },
    "passes": {
        "convert": {
            "type": "OnnxConversion",
            "target_opset": 17,
            "save_as_external_data": true,
            "all_tensors_to_one_file": true,
            "external_data_name": "model.onnx.data"
        }
    },
    "log_severity_level": 0,
    "evaluate_input_model": false,
    "host": "local_system",
    "target": "local_system",
    "cache_dir": "cache",
    "output_dir": "footprints/text_encoder"
}
