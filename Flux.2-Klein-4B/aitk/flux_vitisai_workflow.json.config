{
    "$schema": "https://github.com/microsoft/olive-recipes/raw/refs/heads/main/.aitk/configs/config_schema.json",
    "name": "Convert to AMD NPU",
    "oliveFile": {
        "vitisai_config_transformer.json": {
            "ref": "RyzenAI/config_transformer.json"
        },
        "vitisai_config_text_encoder.json": {
            "ref": "RyzenAI/config_text_encoder.json"
        },
        "vitisai_config_vae_decoder.json": {
            "ref": "RyzenAI/config_vae_decoder.json"
        },
        "vitisai_config_vae_encoder.json": {
            "ref": "RyzenAI/config_vae_encoder.json"
        }
    },
    "runtimeOverwrite": {
        "autoGenerated": true,
        "executeRequirement": "AMD/Quark_py3.12.13"
    },
    "executeRuntimeFeatures": [
        "Flux"
    ],
    "runtime": {
        "autoGenerated": true,
        "name": "Evaluate on",
        "type": "enum",
        "displayNames": [
            "AMD NPU"
        ],
        "path": "systems.target_system.accelerators.0.execution_providers.0",
        "values": [
            "VitisAIExecutionProvider"
        ],
        "readOnly": false
    },
    "optimizationPaths": [
        {
            "path": "passes.aitkpython.model_precision"
        }
    ],
    "optimizationDefault": "bf16",
    "aitkPython": "flux_vitisai_workflow.py",
    "sections": [
        {
            "autoGenerated": true,
            "name": "Convert",
            "phase": "Conversion",
            "parameters": [],
            "toggle": {
                "autoGenerated": true,
                "name": "Convert to ONNX format",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        },
        {
            "name": "Optimization",
            "phase": "Quantization",
            "parameters": [
                {
                    "name": "Precision",
                    "description": "Precision of model",
                    "type": "enum",
                    "displayNames": [
                        "Bf16"
                    ],
                    "displayType": "RadioGroup",
                    "path": "passes.aitkpython.model_precision",
                    "values": [
                        "bf16"
                    ]
                }
            ],
            "disableToggleGeneration": true,
            "toggle": {
                "name": "Optimize model",
                "type": "bool",
                "path": "passes.aitkpython",
                "actions": [
                    [],
                    []
                ],
                "readOnly": true
            }
        }
    ]
}
