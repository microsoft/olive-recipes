{
    "input_model": {
        "type": "HfModel",
        "model_path": "allenai/OLMo-3-7B-Instruct",
        "load_kwargs": {
            "torch_dtype": "bfloat16",
            "attn_implementation": "eager"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": ["CUDAExecutionProvider"]
                }
            ]
        }
    },
    "passes": {
        "r": {
            "type": "rtn",
            "bits": 4,
            "sym": false,
            "group_size": 128,
            "lm_head": true,
            "embeds": true,
            "overrides": {
                "lm_head": {"bits": 8},
                "model.embed_tokens": {"bits": 8}
            }
        },
        "m": {
            "type": "ModelBuilder",
            "precision": "int4"
        }
    },
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "/home/olmo3_basic",
    "cache_dir": "cache",
    "no_artifacts": true
}
