{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen3.5-2B",
        "load_kwargs": {
            "torch_dtype": "float16"
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": ["WebGpuExecutionProvider"]
                }
            ]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "int4",
            "extra_options": {
                "exclude_embeds": false
            }
        },
        "q": {
            "type": "GraphSurgeries",
            "surgeries": [
                {"surgeon": "QuantizeEmbeddingInt8"},
                {"surgeon": "ShareEmbeddingLmHead"}
            ]
        }
    },
    "evaluators": {
        "mmlu": {
            "type": "LMEvaluator",
            "tasks": ["mmlu"],
            "batch_size": 8
        }
    },
    "evaluator": "mmlu",
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model",
    "cache_dir": "cache",
    "no_artifacts": true
}
