{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen3.5-2B"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "NvTensorRTRTXExecutionProvider"
                    ]
                }
            ]
        }
    },
    "passes": {
        "aitkpython": {
            "type": "AitkPython",
            "precision": "int4",
            "user_script": "qwen_trtrtx_workflow.py"
        }
    },
    "target": "local_system",
    "output_dir": "model/qwen3_5_trtrtx",
    "cache_dir": "cache",
    "no_artifacts": true,
    "evaluate_input_model": false
}
