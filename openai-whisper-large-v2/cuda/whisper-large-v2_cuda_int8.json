{
    "input_model": {
        "type": "HfModel",
        "model_path": "openai/whisper-large-v2",
        "task": "automatic-speech-recognition"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "CUDAExecutionProvider"
                    ]
                }
            ]
        }
    },
    "engine": {
        "target": "local_system"
    },
    "passes": {
        "builder": {
            "type": "ModelBuilder",
            "precision": "fp16"
        },
        "onnx_kquant_quantization": {
            "type": "OnnxKQuantQuantization",
            "bits": 8,
            "block_size": 32
        }
    }
}
