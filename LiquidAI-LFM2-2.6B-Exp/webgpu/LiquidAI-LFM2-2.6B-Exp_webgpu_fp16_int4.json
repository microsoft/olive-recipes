{
    "input_model": {
        "type": "HfModel",
        "model_path": "LiquidAI/LFM2-2.6B-Exp",
        "load_kwargs": { "torch_dtype": "float16" }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [{ "device": "gpu", "execution_providers": ["WebGpuExecutionProvider"] }]
        }
    },
    "passes": {
        "m": {
            "type": "ModelBuilder",
            "precision": "int4",
            "int4_block_size": 32
        }
    },
    "target": "local_system",
    "log_severity_level": 0,
    "output_dir": "model",
    "cache_dir": "cache",
    "no_artifacts": true
}
