{
    "input_model": {
        "type": "PyTorchModel",
        "model_path": "nvidia/parakeet-tdt-0.6b-v2",
        "model_loader": "encoder_model_loader",
        "model_script": "src/parakeet_model_load.py",
        "io_config": {
            "input_names": ["audio_signal", "length"],
            "output_names": ["outputs", "encoded_lengths"],
            "dynamic_axes": {
                "audio_signal": {"0": "batch", "2": "time"},
                "length": {"0": "batch"},
                "outputs": {"0": "batch", "2": "time_out"},
                "encoded_lengths": {"0": "batch"}
            },
            "dynamic_shapes": [
                {"0": "batch", "2": "time"},
                {"0": "batch"}
            ]
        },
        "dummy_inputs_func": "encoder_dummy_inputs"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "cpu",
                    "execution_providers": ["CPUExecutionProvider"]
                }
            ]
        }
    },
    "passes": {
        "convert": {
            "type": "OnnxConversion",
            "target_opset": 21,
            "dynamic": true,
            "use_dynamo_exporter": true
        },
        "fusion": {
            "type": "OrtTransformersOptimization",
            "model_type": "conformer",
            "num_heads": 8,
            "hidden_size": 1024,
            "opt_level": 0,
            "only_onnxruntime": false,
            "optimization_options": {
                "use_multi_head_attention": false
            }
        },
        "quantization": {
            "type": "OnnxKQuantQuantization",
            "block_size": 32,
            "accuracy_level": 4,
            "save_as_external_data": true,
            "external_data_name": "encoder.onnx.data"
        }
    },
    "target": "local_system",
    "output_dir": "build/onnx_models_int4/encoder.onnx",
    "no_artifacts": true
}
