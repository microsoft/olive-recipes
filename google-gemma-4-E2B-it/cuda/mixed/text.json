{
    "input_model": {
        "type": "HfModel",
        "model_path": "google/gemma-4-E2B-it"
    },
    "passes": {
        "export": {
            "type": "MobiusBuilder",
            "precision": "fp16",
            "components_to_export": ["model"]
        },
        "int4_quantize": {
            "type": "OnnxKQuantQuantization",
            "bits": 4,
            "block_size": 32,
            "save_as_external_data": true
        }
    },
    "target": {
        "type": "LocalSystem",
        "accelerators": [{ "device": "gpu", "execution_providers": ["CUDAExecutionProvider"] }]
    },
    "no_artifacts": true,
    "output_dir": "cuda/mixed/models/decoder"
}
